# Editor configuration, see https://editorconfig.org
root = true

[*]
end_of_line = lf
charset = utf-8
indent_style = space
indent_size = 2
insert_final_newline = true

[*.md]
max_line_length = off
trim_trailing_whitespace = false

[*.html]
max_line_length = off
indent_size = 4

[*.css]
max_line_length = off
indent_size = 2

[*.py]
max_line_length = 80
indent_size = 4

[*.js]
max_line_length = 120
